# ── 에이전트 ──────────────────────────────
UPSTAGE_API_KEY=

# ── 데이터베이스 (Supabase) ───────────────
# 로컬: postgresql+asyncpg://postgres:password@localhost:5432/taskpilot
# Railway: Supabase Session pooler URI (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/taskpilot

# ── 인증 (Supabase Auth) ──────────────────
# Supabase 대시보드 → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase 대시보드 → Project Settings → API → anon public key
SUPABASE_ANON_KEY=your-anon-public-key

# ── CORS ──────────────────────────────────
# 로컬: http://127.0.0.1:5173,http://localhost:5173
# 배포: Vercel 프론트엔드 주소 (https://your-app.vercel.app)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ── 프론트엔드 (Vercel 환경변수로 설정) ────
# VITE_API_BASE_URL=https://your-app.railway.app
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── LangSmith (선택) ──────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ── ChromaDB (선택, schedule_memory 확장용) ─
CHROMA_MODE=embedded
CHROMA_HOST=localhost
CHROMA_PORT=8000


# ════════════════════════════════════════════
# 배포용 (Railway 환경변수로 설정)
# ════════════════════════════════════════════

# ── 에이전트 ──────────────────────────────
UPSTAGE_API_KEY=

# ── 데이터베이스 (Supabase Session pooler) ─ 우리 거에 맞게 수정 필요
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# ── 인증 ────────────────────────────────── 우리 거에 맞게 수정 필요
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# ── CORS (Vercel 프론트엔드 주소) ────────── 우리 거에 맞게 수정 필요
CORS_ORIGINS=https://your-app.vercel.app

# ── LangSmith (선택) ────────────────────── 
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
